# ─── Minecraft Server ───────────────────────────────────────────────
MC_HOST=your.server.ip
MC_PORT=25565
MC_VERSION=1.20.1

# ─── Auth Plugin Settings ───────────────────────────────────────────
# This password is used for BOTH /register AND /login automatically
# Make it strong — all bot accounts will use this same password
LOGIN_PASSWORD=BotPass123!

# ─── Discord Bot ────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here
DISCORD_PREFIX=!

# ─── Account Switching ──────────────────────────────────────────────
# Auto-switch X minutes before host kicks (set ~5 min less than host limit)
# Set to 0 to only switch when actually kicked
AUTO_SWITCH_MINUTES=50

# Seconds to wait before reconnecting after a kick
RECONNECT_DELAY=5
